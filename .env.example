# The HTTP server binds to loopback by default because Finora has no auth layer.
FINORA_HOST=127.0.0.1
FINORA_PORT=3011

# Defaults to ~/.finora/finora.db.
# FINORA_DATA_DIR=/absolute/path
# FINORA_DATABASE_PATH=/absolute/path/finora.db

# Ceiling (tokens) for the built-in local model's context window. The engine sizes
# the KV cache to each prompt and grows on demand up to this value; a lower ceiling
# bounds worst-case RAM, a higher one allows larger prompts. Clamped to a supported
# range and further bounded by the model's trained context. Defaults to 32768.
# FINORA_BUILTIN_CONTEXT=32768
