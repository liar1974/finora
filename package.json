{
  "name": "finora",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local-first personal finance data service.",
  "engines": {
    "node": ">=22.13"
  },
  "bin": {
    "finora": "dist/cli.js"
  },
  "scripts": {
    "dev": "pnpm build:web && tsx src/cli.ts serve",
    "cli": "tsx src/cli.ts",
    "mcp": "tsx src/mcp/server.ts",
    "build": "tsc -p tsconfig.build.json && pnpm build:web",
    "build:web": "vite build",
    "build:desktop-backend": "esbuild src/desktop-backend.ts --bundle --minify --platform=node --format=esm --outfile=dist/desktop/backend/desktop-backend.mjs",
    "build:desktop-resources": "node scripts/prepare-desktop-resources.mjs",
    "start": "node dist/cli.js serve",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "pnpm build:desktop-resources && tauri build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root .",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.89",
    "@ai-sdk/google": "^3.0.86",
    "@ai-sdk/openai": "^3.0.77",
    "@ai-sdk/openai-compatible": "^2.0.54",
    "@modelcontextprotocol/sdk": "^1.17.5",
    "ai": "^6.0.214",
    "csv-parse": "^6.1.0",
    "pdfjs-dist": "^6.1.200",
    "plaid": "^42.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "snaptrade-typescript-sdk": "^10.0.17",
    "vega": "5.30.0",
    "vega-embed": "6.26.0",
    "vega-lite": "5.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^22.18.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^8.1.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@11.6.0"
}
