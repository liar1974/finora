{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Finora",
  "version": "0.1.0",
  "identifier": "com.finora.desktop",
  "build": {
    "frontendDist": "../dist/http/web"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/desktop"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    }
  }
}
